#!/bin/sh
IGNORE=''''
# CR-only input: three segments separated by \r with no \n anywhere.
# Mimics progress-bar tools that overwrite the line using bare \r.
# Each segment after a \r must be treated as a new line start:
#   - line_color on frame1 must not bleed into frame2 or frame3
#   - frame2 and frame3 are independently colorable
printf 'frame1\rframe2\rframe3' | "$(dirname "$0")"/../bin/hl $debug $options --width 120 -r "$0"
exit $?
'''

[[rule]]
pattern = 'frame1'
line_color = 'bred'

[[rule]]
pattern = 'frame2'
color = 'bblue'
