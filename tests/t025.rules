#!/bin/sh
IGNORE=''''
exec "$(dirname "$0")"/../bin/hl $debug $options -N -r "$0"
'''

# \d in Go's regexp (RE2) matches only ASCII digits [0-9].
# Without -N, regexp2 is used and \d matches Unicode decimal digits too
# (e.g. Arabic-Indic ١٢٣). With -N the Unicode digits are NOT matched,
# so the two engines produce different output on this input.
[[rule]]
pattern = '\d+'
color = 'bred'
